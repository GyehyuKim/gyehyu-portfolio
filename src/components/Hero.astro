---

<section class="min-h-screen flex flex-col justify-center px-4 pt-16 max-w-4xl mx-auto">
  <div class="mb-8">
    <h1 class="text-5xl md:text-7xl font-bold mb-4 leading-tight">
      Gyehyu Kim
    </h1>
    <p class="text-xl md:text-2xl text-[var(--color-text-muted)] font-mono mb-6">
      Field engineer who discovered data could transform operations.
    </p>
    <p class="text-base text-[var(--color-text-muted)] max-w-2xl">
      7.5 years at Samsung Biologics. CMU + Bocconi. 5 side projects in under 6 months.
      Now building AI systems that solve real problems.
    </p>
  </div>

  <!-- TL;DR for recruiters -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <div class="p-4 rounded-lg bg-[var(--color-bg-card)] border border-[var(--color-border)]">
      <div class="metric-pill mb-2">Operations</div>
      <p class="text-sm text-[var(--color-text-muted)]">KRW 8B budget visibility, 250-user data culture shift, KRW 700M audit discovery</p>
    </div>
    <div class="p-4 rounded-lg bg-[var(--color-bg-card)] border border-[var(--color-border)]">
      <div class="metric-pill mb-2">Analytics</div>
      <p class="text-sm text-[var(--color-text-muted)]">SQL/Azure/Power BI, 75K post multimodal analysis, 13.2% engagement lift</p>
    </div>
    <div class="p-4 rounded-lg bg-[var(--color-bg-card)] border border-[var(--color-border)]">
      <div class="metric-pill mb-2">Builder</div>
      <p class="text-sm text-[var(--color-text-muted)]">Python, FastAPI, LLM/RAG, Next.js, AWS, 5 shipped projects</p>
    </div>
  </div>

  <!-- CTA -->
  <div class="flex gap-4 items-center">
    <a href="#contact" class="px-6 py-3 bg-[var(--color-accent)] text-[var(--color-bg)] font-semibold rounded-lg hover:opacity-90 transition-opacity">
      Get in Touch
    </a>
    <a href="/resume.pdf" class="px-6 py-3 border border-[var(--color-border)] text-[var(--color-text)] rounded-lg hover:border-[var(--color-accent)] transition-colors" download>
      Download Resume
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="mt-16 flex flex-col items-center text-[var(--color-text-muted)] text-sm animate-bounce">
    <span>Scroll the story</span>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M12 5v14M19 12l-7 7-7-7" />
    </svg>
  </div>
</section>

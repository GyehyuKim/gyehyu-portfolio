---
interface Props {
  title: string;
  period: string;
  institution?: string;
  description: string;
  metrics: Array<{ label: string; value: string }>;
  index: number;
}

const { title, period, institution, description, metrics, index } = Astro.props;
const positionClass = index % 2 === 0 ? 'lg:pr-12 lg:ml-0' : 'lg:pl-12 lg:ml-auto';
---

<article class:list={["timeline-card relative pl-12 lg:pl-0 lg:w-1/2 mb-12", positionClass]} tabindex="0">
  <div class="timeline-node" aria-hidden="true"></div>

  <div class="p-6 rounded-lg bg-[var(--color-bg-card)] border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors">
    <div class="flex items-center gap-2 mb-2">
      <time class="text-sm font-mono text-[var(--color-accent)]">{period}</time>
      {institution && <span class="text-sm text-[var(--color-text-muted)]">| {institution}</span>}
    </div>

    <h3 class="text-xl font-bold mb-3">{title}</h3>
    <p class="text-[var(--color-text-muted)] text-sm mb-4">{description}</p>

    <div class="flex flex-wrap gap-2">
      {metrics.map((m) => (
        <span class="metric-pill" aria-label={`${m.label}: ${m.value}`}>
          {m.value}
        </span>
      ))}
    </div>
  </div>
</article>
